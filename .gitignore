# Learn more: https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files
# Expo: https://docs.expo.dev/more/glossary-of-terms/#gitignore

# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# Yarn (v2+); keep Berry release files if you commit them
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# ─── Expo ───────────────────────────────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/

# Auto-generated by Expo (`npx expo start`) — do not commit per expo-env.d.ts
expo-env.d.ts

# ─── EAS Build / credentials (never commit secrets) ─────────────────────────
eas-build-local-credentials.json
credentials.json
credentials/

# ─── Native (prebuild / local builds) ───────────────────────────────────────
ios/
android/
.kotlin/

# ─── Metro bundler ──────────────────────────────────────────────────────────
.metro-health-check*
.metro-cache/

# ─── Logs & debug ───────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*
lerna-debug.*
*.log

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── TypeScript / tooling caches ────────────────────────────────────────────
*.tsbuildinfo
.eslintcache
.prettiercache
*.tsbuildinfo.*

# ─── Testing & coverage ────────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ─── Certificates & signing (never commit) ──────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.keystore
*.mobileprovision
*.orig.*
*.pem

# ─── Mobile build artifacts (local / CI drops) ─────────────────────────────
*.apk
*.aab
*.ipa
*.dSYM.zip

# ─── Android profilers / dumps ───────────────────────────────────────────────
*.hprof

# ─── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── Windows ────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Linux / editors ────────────────────────────────────────────────────────
*~
*.swp
*.swo

# ─── IDEs ───────────────────────────────────────────────────────────────────
.idea/
*.sublime-project
*.sublime-workspace

# Optional: uncomment if you do not share editor settings in-repo
# .vscode/
